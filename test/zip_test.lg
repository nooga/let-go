;; Tests for the zip namespace (functional zippers)
(ns test.zip-test
  (:require [test :refer :all]
            [zip :as z]))

;; --- Basic zipper creation and navigation ---

(deftest vector-zip-node-test
  (testing "vector-zip and node"
    (let [loc (z/vector-zip [1 [2 3] [4 [5]]])]
      (is (= [1 [2 3] [4 [5]]] (z/node loc))))))

(deftest down-test
  (testing "down moves to first child"
    (let [loc (z/vector-zip [1 [2 3] 4])]
      (is (= 1 (z/node (z/down loc)))))))

(deftest right-test
  (testing "right moves to next sibling"
    (let [loc (-> (z/vector-zip [1 2 3]) z/down)]
      (is (= 1 (z/node loc)))
      (is (= 2 (z/node (z/right loc))))
      (is (= 3 (z/node (z/right (z/right loc))))))))

(deftest left-test
  (testing "left moves to previous sibling"
    (let [loc (-> (z/vector-zip [1 2 3]) z/down z/right z/right)]
      (is (= 3 (z/node loc)))
      (is (= 2 (z/node (z/left loc))))
      (is (= 1 (z/node (z/left (z/left loc))))))))

(deftest up-test
  (testing "up moves to parent"
    (let [loc (-> (z/vector-zip [1 [2 3]]) z/down z/right z/down)]
      (is (= 2 (z/node loc)))
      (is (= [2 3] (z/node (z/up loc)))))))

(deftest leftmost-rightmost-test
  (testing "leftmost and rightmost"
    (let [loc (-> (z/vector-zip [1 2 3 4]) z/down z/right z/right)]
      (is (= 3 (z/node loc)))
      (is (= 1 (z/node (z/leftmost loc))))
      (is (= 4 (z/node (z/rightmost loc)))))))

;; --- Path, lefts, rights ---

(deftest lefts-rights-test
  (testing "lefts and rights"
    (let [loc (-> (z/vector-zip [1 2 3 4 5]) z/down z/right z/right)]
      (is (= 3 (z/node loc)))
      (is (= '(1 2) (z/lefts loc)))
      (is (= '(4 5) (z/rights loc))))))

(deftest path-test
  (testing "path returns ancestors"
    (let [loc (-> (z/vector-zip [1 [2 [3]]]) z/down z/right z/down z/right z/down)]
      (is (= 3 (z/node loc)))
      (is (= [[1 [2 [3]]] [2 [3]] [3]] (z/path loc))))))

;; --- Modification ---

(deftest replace-test
  (testing "replace substitutes node"
    (let [loc (-> (z/vector-zip [1 2 3]) z/down z/right)]
      (is (= [1 99 3] (z/root (z/replace loc 99)))))))

(deftest edit-test
  (testing "edit applies function"
    (let [loc (-> (z/vector-zip [1 2 3]) z/down z/right)]
      (is (= [1 12 3] (z/root (z/edit loc + 10)))))))

(deftest insert-left-test
  (testing "insert-left adds left sibling"
    (let [loc (-> (z/vector-zip [1 3]) z/down z/right)]
      (is (= [1 2 3] (z/root (z/insert-left loc 2)))))))

(deftest insert-right-test
  (testing "insert-right adds right sibling"
    (let [loc (-> (z/vector-zip [1 3]) z/down)]
      (is (= [1 2 3] (z/root (z/insert-right loc 2)))))))

(deftest insert-child-test
  (testing "insert-child adds first child"
    (let [loc (z/vector-zip [2 3])]
      (is (= [1 2 3] (z/root (z/insert-child loc 1)))))))

(deftest append-child-test
  (testing "append-child adds last child"
    (let [loc (z/vector-zip [1 2])]
      (is (= [1 2 3] (z/root (z/append-child loc 3)))))))

(deftest remove-test
  (testing "remove deletes node"
    (let [loc (-> (z/vector-zip [1 2 3]) z/down z/right)]
      (is (= [1 3] (z/root (z/remove loc)))))))

;; --- Depth-first traversal ---

(deftest next-traversal-test
  (testing "next does depth-first traversal"
    (let [z0 (z/vector-zip [1 [2 3]])]
      (is (= [1 [2 3]] (z/node z0)))
      (let [z1 (z/next z0)]
        (is (= 1 (z/node z1)))
        (let [z2 (z/next z1)]
          (is (= [2 3] (z/node z2)))
          (let [z3 (z/next z2)]
            (is (= 2 (z/node z3)))
            (let [z4 (z/next z3)]
              (is (= 3 (z/node z4)))
              (is (z/end? (z/next z4))))))))))

(deftest end-test
  (testing "end? detects end of traversal"
    (let [loc (z/vector-zip [])]
      (is (z/end? (z/next loc))))))

;; --- Practical examples ---

(deftest transform-tree-test
  (testing "increment all leaves in a tree"
    (let [root [1 [2 3] [4 [5]]]
          result (loop [loc (z/vector-zip root)]
                   (if (z/end? loc)
                     (z/root loc)
                     (if (z/branch? loc)
                       (recur (z/next loc))
                       (recur (z/next (z/edit loc inc))))))]
      (is (= [2 [3 4] [5 [6]]] result)))))

(deftest seq-zip-test
  (testing "seq-zip works with nested lists"
    (let [loc (z/seq-zip '(1 (2 3)))]
      (is (= '(1 (2 3)) (z/node loc)))
      (is (= 1 (z/node (z/down loc)))))))

(deftest branch-test
  (testing "branch? distinguishes branches from leaves"
    (let [loc (z/vector-zip [1 [2] 3])]
      (is (z/branch? loc))
      (is (not (z/branch? (z/down loc))))
      (is (z/branch? (z/right (z/down loc))))
      (is (not (z/branch? (z/right (z/right (z/down loc)))))))))
