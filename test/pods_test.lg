(ns test.pods-test
  (:require [test :refer :all]))

;; Pod integration tests - skipped if pods not installed.
;; Install with: bb -e '(pods/load-pod (quote org.babashka/go-sqlite3) "0.3.13")'

(deftest transit-codec
  (testing "transit write"
    (is (= "null" (transit/write nil)))
    (is (= "42" (transit/write 42)))
    (is (= "\"~:foo\"" (transit/write :foo)))
    (is (= "[1,2,3]" (transit/write [1 2 3])))
    (is (= "[\"^ \",\"~:a\",1]" (transit/write {:a 1}))))

  (testing "transit read"
    (is (= nil (transit/read "null")))
    (is (= 42 (transit/read "42")))
    (is (= :foo (transit/read "\"~:foo\"")))
    (is (= {:a 1} (transit/read "[\"^ \",\"~:a\",1]"))))

  (testing "roundtrip"
    (let [data {:users [{:name "Alice" :age 30}] :count 1}
          rt (transit/read (transit/write data))]
      (is (= 1 (:count rt)))
      (is (= "Alice" (:name (first (:users rt))))))))

(deftest pods-namespace
  (testing "pods namespace exists"
    (is (some? (find-ns 'pods)))))
