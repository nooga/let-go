;; for comprehension tests
(ns test.for-test
  (:require [test :refer :all]))

(deftest basic-for
  (testing "basic for comprehension"
    (is (= '(1 4 9) (for [x [1 2 3]] (* x x))))))

(deftest nested-for
  (testing "nested bindings"
    (is (= '([1 3] [1 4] [2 3] [2 4])
           (for [x [1 2] y [3 4]] [x y])))))

(deftest for-when
  (testing ":when filter"
    (is (= '(2 4) (for [x [1 2 3 4] :when (even? x)] x)))))

(deftest for-let
  (testing ":let intermediate binding"
    (is (= '(1 4 9)
           (for [x [1 2 3] :let [y (* x x)]] y)))))

(deftest for-when-let-combined
  (testing ":when and :let combined"
    (is (= '(4 16)
           (for [x [1 2 3 4]
                 :when (even? x)
                 :let [y (* x x)]]
             y)))))

(deftest for-lazy
  (testing "for on large range is lazy"
    (is (= [0 1 4 9 16]
           (vec (take 5 (for [x (range 1000)] (* x x))))))))

(deftest for-destructuring
  (testing "destructuring in for"
    (is (= '([:a 1] [:b 2])
           (for [[k v] {:a 1 :b 2}] [k v])))))

(deftest for-nested-three-way
  (testing "three-level nesting"
    (is (= 8 (count (for [x [1 2] y [3 4] z [5 6]] [x y z]))))))
