;; Tests for ns :require in all its forms
(ns test.namespace-require-test
  (:require [test :refer :all]
            [string :as s]
            [set]
            [pprint :as pp]
            [edn]))

(deftest require-as
  (testing ":as alias works for qualified access"
    (is (= "1, 2, 3" (s/join ", " [1 2 3])))
    (is (string? (pp/pprint-str {:a 1})))))

(deftest require-bare-vector
  (testing "bare [ns] without options loads and refers"
    (is (some? (var set/union)))
    (is (= #{1 2 3} (set/union #{1 2} #{2 3})))))

(deftest require-bare-vector-qualified
  (testing "bare [ns] allows qualified access"
    (is (some? (var edn/read-string)))
    (is (= {:a 1} (edn/read-string "{:a 1}")))))

(deftest require-refer-all
  (testing ":refer :all brings all vars into scope"
    ;; test ns itself is required with :refer :all
    (is (some? (var is)))
    (is (some? (var deftest)))
    (is (some? (var testing)))))

(deftest require-multiple
  (testing "multiple requires in one ns form"
    ;; All of string, set, pprint, edn should be loaded
    (is (= "hello" (s/join "" ["h" "e" "l" "l" "o"])))
    (is (= #{1} (set/intersection #{1 2} #{1 3})))
    (is (string? (pp/pprint-str [1 2 3])))
    (is (= [1 2] (edn/read-string "[1 2]")))))

(deftest require-bare-symbol
  (testing "bare symbol require (legacy form)"
    ;; This is tested implicitly — string was required as bare in the ns form
    ;; but let's verify qualified access works for loaded namespaces
    (is (= "HELLO" (string/upper-case "hello")))))

(deftest cross-ns-qualified-access
  (testing "qualified access to any loaded namespace"
    (is (= 3 (core/+ 1 2)))
    (is (= "abc" (core/str "a" "b" "c")))))
