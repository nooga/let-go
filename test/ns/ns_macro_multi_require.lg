
(ns tmp.multiclauses (:require [core :as c]) (:require [core :refer :all]) (:require [test :refer :all]))

(deftest ns-multiple-require-clauses
  (testing "ns with multiple :require clauses"
    (is (not (nil? (var c/+))) true)
    (is (not (nil? (var +))) true)))

(run-tests ns-multiple-require-clauses)


