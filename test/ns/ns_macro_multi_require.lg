(ns test.ns.ns-macro-multi-require
  (:require [core :as c])
  (:require [core :refer :all])
  (:require [test :refer :all]))

(test "ns-multiple-require-clauses"
      (testing "ns with multiple :require clauses"
        (is (not (nil? (var c/+))) true)
        (is (not (nil? (var +))) true)))

