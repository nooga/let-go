(ns test.recur
  (:require [test :refer :all]))

(deftest loop-recur
  (testing "loop/recur"
    (is (= 220
           (loop [val 200
                  cnt 20]
             (if (pos? cnt)
               (recur (inc val) (dec cnt))
               val))) true)))

(deftest loop-let-recur
  (testing "loop/let/recur"
    (is (= 220
           (loop [val 200
                  cnt 20]
             (let [meh 1
                   muh 2]
               (if (pos? cnt)
                 (recur (inc val) (dec cnt))
                 val)))) true)))

(deftest fn-recur
  (testing "fn/recur"
    (let [f (fn [x]
              (if (pos? x)
                (recur (dec x))
                x))]
      (is (= (f 10) 0) true))))

(deftest fn-let-recur
  (testing "fn/let/recur"
    (let [f (fn [x]
              (let [meh 1
                    muh 2]
                (if (pos? x)
                  (recur (dec x))
                  x)))]
      (is (= (f 10) 0) true))))

(deftest fn-loop-recur
  (testing "fn/loop/recur"
    (let [f (fn [n]
              (* 2
                 (loop [x 0]
                   (if (< x n)
                     (recur (inc x))
                     x))))]
      (is (= (f 10) 20) true))))

(deftest fn-loop-let-recur
  (testing "fn/loop/let/recur"
    (let [f (fn [n]
              (* 2
                 (loop [x 0]
                   (let [meh 1
                         muh 2]
                     (if (< x n)
                       (recur (inc x))
                       x)))))]
      (is (= (f 10) 20) true))))

(deftest dotimes-test
  (testing "dotimes"
    (do
      (dotimes [kek 100] (println kek))
      (is true true))))