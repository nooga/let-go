;; Factorial with BigInt support
;; Usage: lg examples/factorial.lg

(defn factorial [n]
  (loop [i 1N acc 1N]
    (if (> i n) acc (recur (+ i 1) (* acc i)))))

(doseq [n [10 20 50 100]]
  (println (str n "! = " (factorial n))))
